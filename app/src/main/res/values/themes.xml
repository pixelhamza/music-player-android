<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.MusicPlayer" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/rose_dust</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/rose_mist</item>
        <item name="colorOnSecondary">@color/espresso</item>
        <item name="colorSurface">@color/cocoa</item>
        <item name="colorOnSurface">@color/warm_white</item>
        <item name="android:colorBackground">@color/espresso</item>
        <item name="android:windowBackground">@color/espresso</item>
        <item name="android:statusBarColor">@color/espresso</item>
        <item name="android:navigationBarColor">@color/espresso</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="materialCardViewStyle">@style/Widget.MusicPlayer.CardView</item>
    </style>

    <style name="Theme.MusicPlayer" parent="Base.Theme.MusicPlayer" />

    <style name="Widget.MusicPlayer.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/mocha</item>
        <item name="cardCornerRadius">24dp</item>
    </style>
</resources>
